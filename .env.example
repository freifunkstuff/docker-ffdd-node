# Beispielwerte fuer lokales Testen mit docker compose.
#
# Nutzung:
#   cp .env.example .env
#   docker compose up --build

# User-Inputs kommen per Env.
# Persistente Laufzeitdaten wie node_id, register_key sowie fastd- und wireguard-secret landen in /data/node.yaml.

# Pflicht: Kontakt fuer den Knoten.
NODE_CONTACT_EMAIL=admin@example.org

# Pflichtfach mit eingeschraenkter Wertemenge.
# Erlaubt: Dresden, Leipzig
NODE_COMMUNITY=Dresden

# Optional: Knotenname fuer Karte/Sysinfo, nicht der Name des Eigentuemers.
NODE_NAME=
NODE_CONTACT_LOCATION=
NODE_CONTACT_NOTE=

# Optional: GPS ist laut Wiki eigentlich Pflicht.
# Im ersten Schritt erzeugt ein fehlender Wert nur eine Warnung und keinen Startabbruch.
NODE_GPS_LATITUDE=
NODE_GPS_LONGITUDE=
NODE_GPS_ALTITUDE=0

FASTD_PORT=5002
WIREGUARD_PORT=51820

# Leer lassen, um die Defaults aus config/defaults.yaml zu verwenden.
BACKBONE_PEERS=

# Leer lassen, um die Defaults aus config/defaults.yaml zu verwenden.
NODE_REGISTRATION_URL=

# 1 bis 6 Stunden
REGISTRAR_INTERVAL=3600
BMXD_PREFERRED_GATEWAY=